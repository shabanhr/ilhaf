generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  favorites     UserFavorite[]

  role      Role      @default(USER)
  Session   Session[]
  Account   Account?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  Report    Report[]
}

model Lyrics {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String
  video         String?
  type          LyricsType
  reciterId     String
  reciter       Reciter        @relation(fields: [reciterId], references: [id])
  otherReciters OtherReciter[]
  favorites     UserFavorite[]
  writers       Writer[]
  topics        Topic[]
  english       String?        @db.Text
  urdu          String?        @db.Text
  p             Boolean        @default(true)
  dop           DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  Report        Report[]
}

model Report {
  id        String       @id @default(cuid())
  userId    String
  lyricsId  String
  mistaken  String       @db.Text
  correct   String       @db.Text
  status    ReportStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lyrics Lyrics @relation(fields: [lyricsId], references: [id], onDelete: Cascade)
}

model UserFavorite {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lyricsId  String
  lyrics    Lyrics   @relation(fields: [lyricsId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, lyricsId])
}

model Topic {
  id        String   @id @default(cuid())
  name      String
  updatedAt DateTime @updatedAt
  lyrics    Lyrics[]
}

model Reciter {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  updatedAt     DateTime       @updatedAt
  lyrics        Lyrics[]
  otherReciters OtherReciter[]
}

model OtherReciter {
  id        String  @id @default(cuid())
  lyricsId  String
  reciterId String
  lyrics    Lyrics  @relation(fields: [lyricsId], references: [id], onDelete: Cascade)
  reciter   Reciter @relation(fields: [reciterId], references: [id], onDelete: Cascade)

  @@unique([lyricsId, reciterId])
  @@index([lyricsId])
  @@index([reciterId])
}

model Writer {
  id        String   @id @default(cuid())
  name      String
  updatedAt DateTime @updatedAt
  lyrics    Lyrics[]
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String  @unique
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?
  user                     User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
}

enum LyricsType {
  NOHA
  MANQABAT
  SALAM
  NAAT
  DUA
  MANAJAT
  HAMAD
  MARSIYA
  RAMZAN_KALAM
  SUFI_KALAM
}

enum ReportStatus {
  PENDING
  APPROVED
  REJECTED
}
